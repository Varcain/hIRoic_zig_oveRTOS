+/****************************************************************************
+ * Name: sai_ioctl
+ *
+ * Description:
+ *   Handle I2S ioctls.  AUDIOIOC_ALLOCBUFFER / AUDIOIOC_FREEBUFFER are
+ *   serviced from the DTCM heap when available.
+ *
+ ****************************************************************************/
+
+static int sai_ioctl(struct i2s_dev_s *dev, int cmd, unsigned long arg)
+{
+  switch (cmd)
+    {
+      case AUDIOIOC_START:
+        {
+          /* SAI DMA transfers are started by enqueuebuffer, not here. */
+
+          return OK;
+        }
+
+      case AUDIOIOC_GETBUFFERINFO:
+        {
+          FAR struct ap_buffer_info_s *info =
+              (FAR struct ap_buffer_info_s *)arg;
+          info->nbuffers = 8;
+          info->buffer_size = 1024;
+          return OK;
+        }
+
+#ifdef HAVE_DTCM_HEAP
+      case AUDIOIOC_ALLOCBUFFER:
+        {
+          FAR struct audio_buf_desc_s *bufdesc =
+              (FAR struct audio_buf_desc_s *)arg;
+          int bufsize = sizeof(struct ap_buffer_s) + bufdesc->numbytes;
+          FAR struct ap_buffer_s *apb;
+
+          apb = mm_zalloc(g_dtcm_heap, bufsize);
+          if (apb == NULL)
+            {
+              return -ENOMEM;
+            }
+
+          apb->i.channels = 1;
+          apb->crefs      = 1;
+          apb->nmaxbytes  = bufdesc->numbytes;
+          apb->nbytes     = 0;
+          apb->flags      = 0;
+          apb->samp       = (FAR uint8_t *)(apb + 1);
+          nxmutex_init(&apb->lock);
+          *bufdesc->u.pbuffer = apb;
+          return sizeof(struct audio_buf_desc_s);
+        }
+
+      case AUDIOIOC_FREEBUFFER:
+        {
+          FAR struct audio_buf_desc_s *bufdesc =
+              (FAR struct audio_buf_desc_s *)arg;
+          mm_free(g_dtcm_heap, bufdesc->u.buffer);
+          return sizeof(struct audio_buf_desc_s);
+        }
+#endif
+
+      default:
+        return -ENOTTY;
+    }
+}
